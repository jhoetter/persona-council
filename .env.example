# Sonaloop environment variables — the COMPLETE list, one line each.
# Everything is optional: a fresh install needs NO .env at all (the server bootstraps itself).
#
# Text generation is performed by the MCP host agent (Claude Code, Cursor, Codex, …).
# Sonaloop does not call text LLM APIs and uses no text API keys. There is no
# deterministic fallback.

# ---------------------------------------------------------------- Storage & data dir
# Where the writable runtime lives (DB, avatars, assets, settings).
# Precedence: SONALOOP_DATA_DIR -> repo/data (source checkout) -> per-user data dir (installed).
SONALOOP_DATA_DIR=
# SQLite only in this build. Default: sqlite:///<data dir>/sonaloop.db
DATABASE_URL=

# ---------------------------------------------------------------- Embeddings (semantic recall)
# Provider for memory embeddings: openai | ollama | none. Default: auto — openai when
# OPENAI_API_KEY is set, else ollama when the local server answers, else none (keyword recall).
SONALOOP_EMBEDDINGS_PROVIDER=
# OpenAI embedding model (openai provider). Default: text-embedding-3-small
OPENAI_EMBEDDING_MODEL=
# Ollama embedding model (ollama provider). Default: nomic-embed-text
SONALOOP_OLLAMA_EMBED_MODEL=
# Ollama server base URL. Default: http://localhost:11434
OLLAMA_HOST=
# Set to 1/true to skip embeddings entirely (keyword-only recall; no provider probing).
PERSONA_COUNCIL_DISABLE_EMBEDDINGS=

# ---------------------------------------------------------------- Avatars (optional images)
# OpenAI is used ONLY for optional persona avatar image generation (+ embeddings above).
OPENAI_API_KEY=
# As of 2026-06-02, OpenAI's image guide lists GPT Image models including
# gpt-image-1.5, gpt-image-1, and gpt-image-1-mini.
OPENAI_IMAGE_MODEL=gpt-image-1.5
# Where generated avatar images are written. Default: <data dir>/avatars
AVATAR_OUTPUT_DIR=

# ---------------------------------------------------------------- Web inspector
# Bind host/port for `sonaloop-web`. Defaults: 127.0.0.1 / 8787
PERSONA_COUNCIL_WEB_HOST=
PERSONA_COUNCIL_WEB_PORT=
# Live event stream (SSE /api/events): how often the events table is polled, in seconds
# (default 1, clamped 0.02-10) — and the keep-alive heartbeat interval (default 15; 0 = off).
SONALOOP_EVENTS_POLL=
SONALOOP_EVENTS_HEARTBEAT=

# ---------------------------------------------------------------- Lifecycle hooks
# Set to 1/true to skip command/webhook hook delivery entirely (in-process handlers still run).
SONALOOP_DISABLE_HOOKS=
# Per-delivery timeout in seconds. Default 10, clamped 1-120.
SONALOOP_HOOK_TIMEOUT=

# ---------------------------------------------------------------- Feedback
# When set, every feedback submission from the web inspector also POSTs a JSON payload
# to this webhook URL (best-effort fan-out; failures never block the submission).
SONALOOP_FEEDBACK_WEBHOOK=

# ---------------------------------------------------------------- Live actuation (walkthroughs)
# Comma-separated EXTRA origins personas may drive live (walk_open). Loopback is always
# allowed; anything else must be explicitly declared here — the safety opt-in.
SONALOOP_OWNED_ORIGINS=

# ---------------------------------------------------------------- Persona catalog (sonaloop-data)
# Local checkout of the sonaloop-data catalog for catalog_search/recommend/pull without
# network. Default: the installed sonaloop-data package, else the published GitHub manifest.
SONALOOP_DATA_CATALOG_ROOT=

# ---------------------------------------------------------------- Simulation & eval tuning
# Max concurrent headless-browser sessions (prototype tests). Default 4, clamped 1-16.
PERSONA_COUNCIL_MAX_BROWSER_SESSIONS=
# Memory-recency half-life in days for recall ranking. Default 30.
PERSONA_COUNCIL_RECENCY_HALFLIFE_DAYS=
# Sampled days per simulated month (period simulation). Default 4.
PERSONA_COUNCIL_SAMPLE_DAYS_PER_MONTH=
# Eval-critic score threshold counting as "top" (1-5). Default 4.
PERSONA_COUNCIL_CRITIC_THRESHOLD=
# Sample size per eval-critic round. Default 12, clamped 1-100.
PERSONA_COUNCIL_CRITIC_SAMPLE_K=

# ---------------------------------------------------------------- Publishing (maintainers only)
# PyPI token for `uv publish` (username is __token__). Create one at
# https://pypi.org/manage/account/token/ and put the REAL value in your local, gitignored
# .env — NEVER here. Rotate immediately if it ever leaks. Starts with "pypi-".
UV_PUBLISH_TOKEN=pypi-REPLACE_WITH_YOUR_TOKEN
