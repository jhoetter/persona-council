# Text generation is performed by the MCP host agent, such as Claude Code or
# Codex. Sonaloop does not call text LLM APIs and does not use text API
# keys. There is no deterministic fallback.

# OpenAI is used only for optional persona avatar image generation.
OPENAI_API_KEY=
# As of 2026-06-02, OpenAI's image guide lists GPT Image models including
# gpt-image-1.5, gpt-image-1, and gpt-image-1-mini.
OPENAI_IMAGE_MODEL=gpt-image-1.5
AVATAR_OUTPUT_DIR=data/avatars

# Local persistence. SQLite is the intended default for the first build.
DATABASE_URL=sqlite:///data/sonaloop.db

# Simulation defaults.
DEFAULT_TIMEZONE=Europe/Berlin
DEFAULT_WORKDAY_START=08:30
DEFAULT_WORKDAY_END=17:30
DEFAULT_SIMULATION_DAYS=1
