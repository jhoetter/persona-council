{
  "title": "Der volle Stuhl (Lo-Fi Journey)",
  "summary": "Steuere deine Zahlen, sieh die Lücke — kein Verkauf.",
  "fidelity": "lofi",
  "start": "intro",
  "screens": [
    {
      "id": "intro",
      "title": "Nach dem Auto — kurz ehrlich",
      "elements": [
        {
          "kind": "text",
          "id": "t1",
          "label": "Wir verkaufen dir nichts. Wir zeigen, was deine eigenen Zahlen bedeuten, wenn dein Einkommen mal ausfällt."
        },
        {
          "kind": "button",
          "id": "go",
          "label": "Zeig mir meine Zahlen",
          "goto": "model",
          "action": "model"
        }
      ]
    },
    {
      "id": "model",
      "title": "Dein voller Stuhl",
      "elements": [
        {
          "kind": "range",
          "id": "einkommen",
          "label": "Netto-Einkommen / Monat",
          "min": 800,
          "max": 4000,
          "step": 100,
          "value": 2000,
          "suffix": " €"
        },
        {
          "kind": "range",
          "id": "sparrate",
          "label": "Monatlich zurückgelegt",
          "min": 0,
          "max": 600,
          "step": 25,
          "value": 100,
          "suffix": " €"
        },
        {
          "kind": "range",
          "id": "angehoerige",
          "label": "Menschen, die von dir abhängen",
          "min": 0,
          "max": 4,
          "step": 1,
          "value": 1
        },
        {
          "kind": "range",
          "id": "schock",
          "label": "Monate ohne Einkommen",
          "min": 1,
          "max": 12,
          "step": 1,
          "value": 6
        },
        {
          "kind": "range",
          "id": "bedarf_pct",
          "label": "Annahme: % des Einkommens, das du brauchst",
          "min": 50,
          "max": 100,
          "step": 5,
          "value": 78,
          "suffix": " %"
        },
        {
          "kind": "computed",
          "id": "monate_voll",
          "label": "So lange trägt dein Polster",
          "formula": "sparrate*12/(einkommen*(bedarf_pct/100)*(1+angehoerige*0.35))",
          "suffix": " Monate",
          "decimals": 1
        },
        {
          "kind": "bar",
          "id": "stuhl",
          "label": "Stuhl voll von deinen Schock-Monaten",
          "formula": "sparrate*12/(einkommen*(bedarf_pct/100)*(1+angehoerige*0.35))",
          "max": "schock",
          "suffix": " Mon."
        },
        {
          "kind": "chart",
          "id": "kurve",
          "label": "Polster über die Schock-Monate",
          "x": {
            "id": "schock",
            "from": 1,
            "to": 12,
            "step": 1
          },
          "series": [
            {
              "label": "getragene Monate",
              "formula": "sparrate*12/(einkommen*(bedarf_pct/100)*(1+angehoerige*0.35))"
            }
          ]
        },
        {
          "kind": "button",
          "id": "go2",
          "label": "Was heißt das für mich?",
          "goto": "verdict",
          "action": "verdict"
        }
      ]
    },
    {
      "id": "verdict",
      "title": "Die ehrliche Antwort",
      "elements": [
        {
          "kind": "computed",
          "id": "luecke",
          "label": "Lücke, die offen bleibt",
          "formula": "max(0,(schock-sparrate*12/(einkommen*(bedarf_pct/100)*(1+angehoerige*0.35)))*(einkommen*(bedarf_pct/100)*(1+angehoerige*0.35)))",
          "prefix": "≈ ",
          "suffix": " €",
          "decimals": 0
        },
        {
          "kind": "verdict",
          "id": "v",
          "cases": [
            {
              "when": "angehoerige==0",
              "text": "Niemand hängt von deinem Einkommen ab — du brauchst das jetzt NICHT. Bau ein kleines Polster. Behalt dein Geld.",
              "tone": "good"
            },
            {
              "when": "(max(0,(schock-sparrate*12/(einkommen*(bedarf_pct/100)*(1+angehoerige*0.35)))*(einkommen*(bedarf_pct/100)*(1+angehoerige*0.35))))<=0",
              "text": "Dein Polster trägt den Schock — kein Schutz nötig.",
              "tone": "good"
            }
          ],
          "else": "Hier klafft eine echte Lücke für Menschen, die von dir abhängen. Ein SCHLANKER Risikoschutz — alle Kosten sichtbar — würde genau das abdecken.",
          "elseTone": "warn"
        }
      ]
    }
  ]
}